generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String              @id @default(cuid())
  name             String?
  email            String?             @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  resyCredential   ResyCredential?
  otGuestProfile   OTGuestProfile?
  targets          ReservationTarget[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ResyCredential {
  id                String    @id @default(cuid())
  userId            String    @unique
  encryptedEmail    String
  encryptedPassword String
  encryptedAuthToken String?
  paymentMethodId   String?
  tokenExpiresAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReservationTarget {
  id                String       @id @default(cuid())
  userId            String
  platform          Platform     @default(RESY)
  venueId           Int
  venueName         String
  neighborhood      String?
  cuisine           String?
  date              DateTime
  partySize         Int          @default(2)
  preferredTimes    String[]
  mode              TargetMode   @default(SNIPE)
  snipeAt           DateTime
  status            TargetStatus @default(PENDING)
  bookedSlot        String?
  lastAttemptAt     DateTime?
  notificationEmail String?
  notificationPhone String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts          SnipeAttempt[]

  // Cron hot-path queries run every ~30-60s; index the columns they filter on
  @@index([status, mode, snipeAt])
  @@index([status, mode, date])
  @@index([userId])
}

model OTGuestProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  firstName            String
  encryptedLastName    String
  encryptedPhone       String
  encryptedBearerToken String
  encryptedCardToken   String   @default("")
  cardLast4            String   @default("")
  gpid                 String
  customerId           String
  bearerExpiredAt      DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Platform {
  RESY
  OPENTABLE
}

enum TargetMode {
  SNIPE
  WATCH
}

enum TargetStatus {
  PENDING
  SNIPING
  WATCHING
  BOOKED
  FAILED
  CANCELLED
}

// Community-curated reservation-release info, layered on top of the static
// curated list in lib/restaurants.ts. Keyed by normalized name + platform so it
// survives Resy venueId churn (curated venueIds are intentionally null). When a
// note exists, it overrides the static releaseNotes/releaseTime/daysOut for display
// and snipe-time auto-suggestion.
model VenueReleaseNote {
  id            String   @id @default(cuid())
  nameKey       String   // normalized restaurant name (lowercased, trimmed)
  platform      Platform
  displayName   String   // original-cased name as last saved
  releaseTime   String?  // HH:MM ET 24h — drives auto-suggested Snipe At
  daysOut       Int?     // how many days in advance reservations open
  notes         String   // free-text human-readable release note
  updatedById   String?  // userId of last editor (audit/attribution)
  updatedByName String?  // display name of last editor
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([nameKey, platform])
}

model SnipeAttempt {
  id        String            @id @default(cuid())
  targetId  String
  attemptAt DateTime          @default(now())
  success   Boolean
  error     String?
  slot      String?
  target    ReservationTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId, attemptAt])
}
